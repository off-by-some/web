{
  "name": "website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write "
    ],
    "*.{css,md,json}": "prettier --write"
  },
  "scripts": {
    "dev": "vite dev",
    "predev": "npm run setup:static",
    "prebuild": "npm run clean && npm run fix && npm run lint && npm run setup:static",
    "build": "vite build",
    "postbuild": "cp build/index.html build/404.html && touch build/.nojekyll",
    "deploy": "npm run build && npm run build-storybook:pages && gh-pages -d build --dotfiles",
    "preview": "node scripts/preview.js",
    "prepare": "husky",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "fix": "npm run lint:fix && npm run format",
    "storybook": "NODE_OPTIONS=--disable-warning=DEP0190 storybook dev -p 6006 --no-open --no-version-updates --disable-telemetry",
    "build-storybook": "NODE_OPTIONS=--disable-warning=DEP0190 storybook build",
    "build-storybook:pages": "STORYBOOK_BASE=/web/storybook/ NODE_OPTIONS=--disable-warning=DEP0190 storybook build -o build/storybook",
    "generate:critical-css": "sass src/styles/foundations/index.scss static/index.css --no-source-map --style=compressed",
    "generate:og": "node scripts/generate-og-images.js",
    "generate:favicon": "node scripts/generate-favicon.js",
    "setup:static": "npm run generate:og && npm run generate:favicon && npm run generate:critical-css",
    "clean": "rm -rf static build .lighthouseci metrics/lhci docs/lhci",
    "lighthouse": "rm -rf .lighthouseci metrics/lhci && lhci autorun",
    "screenshot:reports": "node scripts/screenshot-reports.js",
    "screenshot:website": "node scripts/screenshot-website.js",
    "screenshot:all": "npm run lighthouse && npm run screenshot:website && npm run screenshot:reports"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.5",
    "@lhci/cli": "^0.15.1",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^9.1.20",
    "@storybook/mdx2-csf": "^1.1.0",
    "@storybook/svelte": "^9.1.20",
    "@storybook/svelte-vite": "^9.1.20",
    "@storybook/sveltekit": "^9.1.20",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/enhanced-img": "^0.11.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^20.19.43",
    "@typescript-eslint/utils": "^8.65.0",
    "cssnano": "^7.1.9",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-storybook": "^9.1.20",
    "eslint-plugin-svelte": "^3.22.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mdsvex": "^0.12.8",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^3.5.2",
    "rollup-plugin-bundle-stats": "^4.22.2",
    "sass": "^1.101.6",
    "scss": "^0.2.4",
    "sharp": "^0.35.3",
    "storybook": "^9.1.20",
    "svelte": "^5.0.0",
    "svelte-check": "^4.7.3",
    "svelte-preprocess": "^6.0.5",
    "terser": "^5.49.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vite-imagetools": "^10.0.1"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.6",
    "puppeteer": "^24.16.0",
    "yarn": "^1.22.22"
  },
  "overrides": {
    "cookie": "^0.7.2",
    "picomatch": "^4.0.5",
    "sharp": "^0.35.3",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1",
    "vite-imagetools": "^10.0.1"
  }
}
